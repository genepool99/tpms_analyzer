# TPMS Analyzer / rtl_433 Home Assistant project
# Keep source code and docs tracked; ignore logs, databases, generated reports, backups, and local secrets.

# Python cache / bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments / local tooling
.venv/
venv/
env/
.env
.env.*
!.env.example

# Runtime logs from rtl_433
logs/
*.log
*.jsonl
rtl_433.jsonl
rtl_433_events.jsonl

# SQLite runtime databases
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
tpms.sqlite
tpms.sqlite.*

# Generated report output
output/
*.html
tpms_report.html
tpms_status.json

# Vehicle map backups generated by the analyzer
vehicles.backup*.json

# Optional: keep an example vehicle map, but do not accidentally publish your real one
vehicles.json
!vehicles.example.json

# Home Assistant / local install artifacts
.storage/
deps/
tts/
www/rtl_433/tpms_report.html
www/rtl_433/tpms_status.json

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.claude/

# Archives / manual backups
*.bak
*.backup
*.tar
*.tar.gz
*.zip
